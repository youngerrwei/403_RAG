# =========================
# GPU 配置
# =========================
CUDA_VISIBLE_DEVICES=0

# =========================
# vLLM 配置
# =========================
VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_API_KEY=lab-secret-key
VLLM_MODEL_NAME=Qwen/Qwen2.5-14B-Instruct
MAX_LEN=1024

# =========================
# Qdrant 配置
# =========================
QDRANT_HOST=172.18.216.71
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=lab_knowledge_base
QDRANT_RECREATE_COLLECTION=true

# =========================
# Embedding 配置
# =========================
EMBEDDING_MODEL_NAME=./models/bge-m3
EMBEDDING_DEVICE=cuda

# =========================
# Reranker 配置
# =========================
RERANKER_MODEL_NAME=./models/bge-reranker-v2-m3
RERANKER_DEVICE=cuda

# =========================
# 文档与切块参数
# =========================
DOCS_PATH=/mnt/cpu_share
CHUNK_SIZE=1024
CHUNK_OVERLAP=32
INITIAL_RETRIEVAL_K=128
FINAL_TOP_K=16

# =========================
# 知识库路径
# =========================
KNOWLEDGE_BASE_ROOT=/mnt/cpu_share
ENABLE_FILESYSTEM_TOOL=true
FILE_SEARCH_LIMIT=200
DIRECTORY_CHILD_LIMIT=10

# =========================
# DEBUG 配置
# =========================
DEBUG_MODE=true